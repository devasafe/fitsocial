# Porta da API
PORT=4000

# Conexão MongoDB (local ou Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/fitsocial

# Segredo para assinar os JWT (troque por um valor longo e aleatório)
JWT_SECRET=troque-este-valor-por-um-segredo-longo-e-aleatorio
JWT_EXPIRES_IN=30d

# Camada de IA (Fatias 2 e 3). Provider trocável: gemini (default).
AI_PROVIDER=gemini
# Chave gratuita do Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Modelo do Gemini (ajuste conforme o disponível no seu tier gratuito)
GEMINI_MODEL=gemini-3.5-flash

# Origem permitida para CORS (o app em dev). Use * apenas em desenvolvimento.
CORS_ORIGIN=*

# YouTube Data API v3 — habilita os vídeos de execução dos exercícios (opcional).
# Sem esta chave, o app mostra um botão que abre a busca no YouTube por fora.
# Para obter: Google Cloud Console → enable "YouTube Data API v3" → API key (https://console.cloud.google.com/apis/library/youtube.googleapis.com)
YOUTUBE_API_KEY=
